# Codex project rules.
# Reference: https://developers.openai.com/codex/rules

# ----------------------------------------------------------------------
# Allow rules (migrated from .claude/settings.json permissions.allow)
# ----------------------------------------------------------------------
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["mkdir"], decision = "allow")
prefix_rule(pattern = ["bundle", "install"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["./bin/format"], decision = "allow")
prefix_rule(pattern = ["./bin/setup"], decision = "allow")
prefix_rule(pattern = ["gemini"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["diff"], decision = "allow")
prefix_rule(pattern = ["afplay"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["make", "deploy-dry-run"], decision = "allow")
prefix_rule(pattern = ["whois"], decision = "allow")
prefix_rule(pattern = ["dig"], decision = "allow")
prefix_rule(pattern = ["command", "-v"], decision = "allow")
prefix_rule(pattern = ["npm", "root"], decision = "allow")
prefix_rule(pattern = ["curl"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["say"], decision = "allow")
prefix_rule(pattern = ["test"], decision = "allow")
prefix_rule(pattern = ["md-open"], decision = "allow")
prefix_rule(pattern = ["gh", "pr", "view"], decision = "allow")
prefix_rule(pattern = ["gh", "pr", "diff"], decision = "allow")
prefix_rule(pattern = ["git", "log"], decision = "allow")
prefix_rule(pattern = ["codex", "exec"], decision = "allow")
prefix_rule(pattern = ["docker", "compose"], decision = "allow")
prefix_rule(pattern = ["docker", "compose", "exec"], decision = "allow")
prefix_rule(pattern = ["docker", "compose", "logs"], decision = "allow")
prefix_rule(pattern = ["brew", "list"], decision = "allow")
prefix_rule(pattern = ["brew", "info"], decision = "allow")
prefix_rule(pattern = ["brew", "doctor"], decision = "allow")

# ----------------------------------------------------------------------
# Forbidden rules (migrated from .claude/settings.json permissions.deny)
# ----------------------------------------------------------------------
prefix_rule(pattern = ["git", "push", "--force"], decision = "forbidden")
prefix_rule(pattern = ["git", "push", "-f"], decision = "forbidden")
prefix_rule(pattern = ["git", "reset", "--hard"], decision = "forbidden")
prefix_rule(pattern = ["git", "clean", "-fdx"], decision = "forbidden")
prefix_rule(pattern = ["diskutil", "eraseDisk"], decision = "forbidden")
prefix_rule(pattern = ["mkfs"], decision = "forbidden")
prefix_rule(pattern = ["fdisk"], decision = "forbidden")
prefix_rule(pattern = ["parted"], decision = "forbidden")
prefix_rule(pattern = ["dd"], decision = "forbidden")
prefix_rule(pattern = ["docker", "system", "prune"], decision = "forbidden")
prefix_rule(pattern = ["rm"], decision = "forbidden")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
