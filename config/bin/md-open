#!/bin/bash

set -eu

if [ "$#" -lt 1 ]; then
  echo "使い方: md-open <file.md> [more.md ...]" >&2
  exit 1
fi

for path in "$@"; do
  case "$path" in
    *.md) ;;
    *)
      echo "エラー: .md ファイルのみ開けます: $path" >&2
      exit 2
      ;;
  esac

  if [ ! -e "$path" ]; then
    echo "エラー: ファイルが存在しません: $path" >&2
    exit 3
  fi
done

open "$@"
